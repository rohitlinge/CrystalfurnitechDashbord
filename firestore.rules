rules_version = '2';
// Crystal Furnitech B2B portal — deployed to the "default" Firestore database (asia-south1)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function dealerDoc() {
      return get(/databases/$(database)/documents/dealers/$(request.auth.uid));
    }

    function getRole() {
      return dealerDoc().data.role;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@crystalfurnitech.com' ||
        (exists(/databases/$(database)/documents/dealers/$(request.auth.uid)) && getRole() == 'admin')
      );
    }

    function isSalesExecutive() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/dealers/$(request.auth.uid)) &&
        dealerDoc().data.get('role', '') == 'sales_executive' &&
        dealerDoc().data.get('status', '') == 'Approved';
    }

    function executiveAssignedDealerIds() {
      return dealerDoc().data.get('assignedDealerIds', []);
    }

    function isExecutiveAssignedToDealer(dealerId) {
      return isSalesExecutive() && (
        dealerId in executiveAssignedDealerIds() ||
        (
          exists(/databases/$(database)/documents/dealers/$(dealerId)) &&
          get(/databases/$(database)/documents/dealers/$(dealerId)).data.get('assignedExecutiveId', '') == request.auth.uid
        )
      );
    }

    function isApprovedDealer() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/dealers/$(request.auth.uid)) &&
        getRole() == 'dealer' &&
        dealerDoc().data.status == 'Approved';
    }

    function isAssignedDealer(dealerId) {
      return exists(/databases/$(database)/documents/dealers/$(dealerId)) &&
        get(/databases/$(database)/documents/dealers/$(dealerId)).data.assignedExecutiveId == request.auth.uid;
    }

    function isValidDealer(data) {
      return data.companyName is string && data.companyName.size() >= 3 && data.companyName.size() <= 100 &&
             data.ownerName is string && data.ownerName.size() >= 2 && data.ownerName.size() <= 100 &&
             data.mobile is string && data.mobile.size() >= 10 && data.mobile.size() <= 15 &&
             data.email is string && data.email.size() <= 100 &&
             (data.gstNumber == 'N/A' || (data.gstNumber is string && data.gstNumber.size() <= 20)) &&
             data.city is string && data.city.size() >= 2 && data.city.size() <= 50 &&
             data.state is string && data.state.size() >= 2 && data.state.size() <= 50 &&
             data.address is string && data.address.size() >= 5 && data.address.size() <= 300 &&
             (!('creditLimit' in data) || ((data.creditLimit is int || data.creditLimit is number) && data.creditLimit >= 0)) &&
             (!('outstandingBalance' in data) || ((data.outstandingBalance is int || data.outstandingBalance is number) && data.outstandingBalance >= 0)) &&
             (!('creditDays' in data) || ((data.creditDays is int || data.creditDays is number) && data.creditDays >= 0));
    }

    function isValidSalesExecutive(data) {
      return data.ownerName is string && data.ownerName.size() >= 2 && data.ownerName.size() <= 100 &&
             data.mobile is string && data.mobile.size() >= 10 && data.mobile.size() <= 15 &&
             data.email is string && data.email.size() <= 100 &&
             data.companyName is string && data.companyName.size() >= 2 && data.companyName.size() <= 100 &&
             data.role == 'sales_executive' &&
             data.status == 'Approved';
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() >= 3 && data.name.size() <= 100 &&
             data.isActive is bool;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() >= 3 && data.name.size() <= 100 &&
             data.sku is string && data.sku.size() >= 3 && data.sku.size() <= 50 &&
             (data.price is int || data.price is float || data.price is number) &&
             (data.availableStock is int || data.availableStock is number) && data.availableStock >= 0 &&
             data.status in ['Available', 'Out Of Stock'];
    }

    function isValidRequirement(data) {
      return (data.quantityRequested is int || data.quantityRequested is number) && data.quantityRequested >= 1 &&
             data.productId is string && data.productId.size() > 0 &&
             data.productName is string && data.productName.size() >= 3 &&
             data.dealerId is string && data.dealerId.size() > 0 &&
             data.status in ['Pending', 'Approved', 'Production', 'Packed', 'Dispatched', 'Delivered', 'Cancelled', 'Fulfilled'] &&
             (!('orderValue' in data) || ((data.orderValue is int || data.orderValue is number) && data.orderValue >= 0));
    }

    function isValidLedger(data) {
      return data.dealerId is string && data.dealerId.size() > 0 &&
             data.description is string && data.description.size() >= 1 && data.description.size() <= 200 &&
             (data.debit is int || data.debit is number) && data.debit >= 0 &&
             (data.credit is int || data.credit is number) && data.credit >= 0 &&
             (data.balance is int || data.balance is number) && data.balance >= 0 &&
             data.type in ['opening', 'payment', 'order', 'order_cancel', 'credit_note', 'adjustment'];
    }

    function isValidVisit(data) {
      return data.executiveId is string && data.executiveId.size() > 0 &&
             data.dealerId is string && data.dealerId.size() > 0 &&
             data.dealerCompanyName is string && data.dealerCompanyName.size() >= 2 &&
             data.purpose is string && data.purpose.size() >= 2 && data.purpose.size() <= 200 &&
             data.outcome in ['completed', 'scheduled', 'cancelled'];
    }

    function isValidFollowUp(data) {
      return data.executiveId is string && data.executiveId.size() > 0 &&
             data.dealerId is string && data.dealerId.size() > 0 &&
             data.dealerCompanyName is string && data.dealerCompanyName.size() >= 2 &&
             data.subject is string && data.subject.size() >= 2 && data.subject.size() <= 200 &&
             data.status in ['pending', 'completed', 'cancelled'];
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /test/{docId} {
      allow read: if isSignedIn();
    }

    match /dealers/{userId} {
      allow get: if isSignedIn() && (
        isOwner(userId) ||
        isAdmin() ||
        (isSalesExecutive() && resource.data.role == 'dealer' && resource.data.assignedExecutiveId == request.auth.uid)
      );
      allow list: if isAdmin() || (
        isSalesExecutive() && resource.data.get('assignedExecutiveId', '') == request.auth.uid
      );

      allow create: if isSignedIn() && isValidId(userId) && (
        (
          isAdmin() &&
          request.resource.data.role == 'dealer' &&
          request.resource.data.status == 'Approved' &&
          request.resource.data.uid == userId &&
          isValidDealer(request.resource.data)
        ) || (
          isAdmin() &&
          request.resource.data.role == 'sales_executive' &&
          request.resource.data.status == 'Approved' &&
          request.resource.data.uid == userId &&
          isValidSalesExecutive(request.resource.data)
        ) || (
          isOwner(userId) &&
          request.resource.data.role == 'dealer' &&
          request.resource.data.status == 'Pending Approval' &&
          request.resource.data.uid == userId &&
          (request.auth.token.email == null || request.resource.data.email.lower() == request.auth.token.email.lower())
        )
      );

      allow update: if isSignedIn() && isValidId(userId) && (
        isAdmin() || (
          isOwner(userId) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.uid == resource.data.uid &&
          (
            (
              isValidDealer(request.resource.data) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['companyName', 'ownerName', 'mobile', 'address', 'city', 'state'])
            )
            ||
            (
              isOwner(userId) &&
              resource.data.role == 'dealer' &&
              resource.data.status == 'Approved' &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['outstandingBalance']) &&
              request.resource.data.outstandingBalance >= 0
            )
          )
        )
      );

      allow delete: if isAdmin() && isValidId(userId);
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidId(categoryId) && isValidCategory(request.resource.data);
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin() && isValidId(productId) && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(request.resource.data);
    }

    match /requirements/{requirementId} {
      allow get: if isSignedIn() && isValidId(requirementId) && (
        resource.data.dealerId == request.auth.uid ||
        isAdmin() ||
        isExecutiveAssignedToDealer(resource.data.dealerId)
      );
      allow list: if isSignedIn() && (
        resource.data.dealerId == request.auth.uid ||
        isAdmin() ||
        isExecutiveAssignedToDealer(resource.data.dealerId)
      );

      allow create: if isSignedIn() && isValidId(requirementId) && (
        isAdmin() ||
        (
          isApprovedDealer() &&
          isValidRequirement(request.resource.data) &&
          request.resource.data.dealerId == request.auth.uid &&
          request.resource.data.status == 'Pending'
        )
      );

      allow update: if isSignedIn() && isValidId(requirementId) && (
        isAdmin() || (
          isApprovedDealer() &&
          resource.data.dealerId == request.auth.uid &&
          isValidRequirement(request.resource.data) &&
          request.resource.data.status == 'Cancelled' &&
          resource.data.status == 'Pending' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        )
      );

      allow delete: if isAdmin() && isValidId(requirementId);
    }

    match /ledger/{entryId} {
      allow get: if isSignedIn() && isValidId(entryId) && (
        resource.data.dealerId == request.auth.uid ||
        isAdmin() ||
        isExecutiveAssignedToDealer(resource.data.dealerId)
      );
      allow list: if isSignedIn() && (
        resource.data.dealerId == request.auth.uid ||
        isAdmin() ||
        isExecutiveAssignedToDealer(resource.data.dealerId)
      );
      allow create: if isSignedIn() && isValidId(entryId) && isValidLedger(request.resource.data) && (
        isAdmin() || (
          isApprovedDealer() &&
          request.resource.data.dealerId == request.auth.uid &&
          request.resource.data.type in ['order', 'order_cancel']
        )
      );
      allow update, delete: if isAdmin() && isValidId(entryId);
    }

    match /visits/{visitId} {
      allow get: if isSignedIn() && isValidId(visitId) && (
        isAdmin() || resource.data.executiveId == request.auth.uid
      );
      allow list: if isSignedIn() && (
        isAdmin() || resource.data.executiveId == request.auth.uid
      );
      allow create: if isSignedIn() && isValidId(visitId) && isValidVisit(request.resource.data) && (
        isAdmin() ||
        (
          isSalesExecutive() &&
          request.resource.data.executiveId == request.auth.uid &&
          isAssignedDealer(request.resource.data.dealerId)
        )
      );
      allow update, delete: if isSignedIn() && isValidId(visitId) && (
        isAdmin() || (isSalesExecutive() && resource.data.executiveId == request.auth.uid)
      );
    }

    match /followUps/{followUpId} {
      allow get: if isSignedIn() && isValidId(followUpId) && (
        isAdmin() || resource.data.executiveId == request.auth.uid
      );
      allow list: if isSignedIn() && (
        isAdmin() || resource.data.executiveId == request.auth.uid
      );
      allow create: if isSignedIn() && isValidId(followUpId) && isValidFollowUp(request.resource.data) && (
        isAdmin() ||
        (
          isSalesExecutive() &&
          request.resource.data.executiveId == request.auth.uid &&
          isAssignedDealer(request.resource.data.dealerId)
        )
      );
      allow update, delete: if isSignedIn() && isValidId(followUpId) && (
        isAdmin() || (isSalesExecutive() && resource.data.executiveId == request.auth.uid)
      );
    }

    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && isValidId(notificationId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && isValidId(notificationId) &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isValidId(notificationId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
  }
}
